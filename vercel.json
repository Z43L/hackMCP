{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "memory": 3008
    }
  },
  "rewrites": [
    { "source": "/mcp", "destination": "/api/index" },
    { "source": "/health", "destination": "/api/index" },
    { "source": "/info", "destination": "/api/index" }
  ]
}
