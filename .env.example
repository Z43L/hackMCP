# HackMCP environment variables

# Transport: "stdio" (default) or "http"
TRANSPORT=stdio

# HTTP server config (only used when TRANSPORT=http)
PORT=3000
HOST=0.0.0.0

# Stateless mode for serverless deployments (Vercel, etc.)
# In stateless mode, each request gets a fresh transport - no session state
MCP_STATELESS=false

# Path to cloned HackTricks repo (defaults to ./hacktricks/src or ../hacktricks/src)
# HACKTRICKS_PATH=/path/to/hacktricks/src
